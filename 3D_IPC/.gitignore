# Build artifacts (CMake out-of-tree)
build/

# Simulation output
frames_*/
tmp_full/

# Local Python audit / debug scripts
# tools/<x> rather than tools/ so the !exception below can reach in.
tools/*
!tools/decimate_obj.py

# Stanford XYZ RGB dragon source mesh -- 11 MB, fetch from
# https://github.com/hughsk/stanford-dragon if you want to regenerate
# xyzrgb_dragon_12k.obj via tools/decimate_obj.py
xyzrgb_dragon_full.obj

# Top-level run logs from background sim invocations
*_log.txt

# Debug OBJ dumps written by visualization_test
vis_debug/

# macOS
.DS_Store

# Claude Code scheduled-tasks runtime lock
.claude/scheduled_tasks.lock
